# ---- LM Studio (OpenAI-совместимый сервер) ----
# По умолчанию LM Studio слушает на 1234 порту
LMSTUDIO_BASE_URL=http://95.31.3.115:8443/v1
LMSTUDIO_API_KEY=sk-lm-r7pVzlZM:CNacqVWPIhkIQFRdZtQ7
# Имя модели как оно отображается в LM Studio (вкладка Developer / Server).
# Для зрения нужна VL-модель, напр. qwen2.5-vl-7b-instruct
# Для текстового режима подойдёт qwen3-30b-a3b
MODEL_NAME=qwen/qwen3.6-35b-a3b

# ---- Режим восприятия ----
# true  -> слать скриншоты модели (нужна vision-модель)
# false -> текстовый режим без картинок (для qwen3-30b-a3b)
VISION_ENABLED=false

# ---- Параметры агентного цикла ----
MAX_STEPS=40
STEP_DELAY=0.8
TEMPERATURE=0.1
MAX_TOKENS=1024
# Картинка масштабируется по большей стороне до этого размера (px) перед отправкой
SCREENSHOT_MAX_SIDE=1280
# Индекс монитора для mss (1 = основной)
MONITOR_INDEX=1

# ---- Бэкенд управления вводом ----
# pyautogui (X11) или xdotool (X11) или ydotool (Wayland, требует ydotoold+root)
INPUT_BACKEND=pyautogui

# ---- HTTP сервис ----
HOST=127.0.0.1
PORT=8077

# ---- Безопасность ----
# Если задан, запросы к API должны содержать заголовок X-API-Key с этим значением
SERVICE_API_KEY=dqfH2WkL!@

# ---- Логи ----
LOG_LEVEL=INFO
LOG_DIR=logs
# Сохранять ли скриншоты каждого шага на диск (для отладки)
SAVE_STEP_SCREENSHOTS=true
